{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(nix build:*)",
      "Bash(nix eval:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix flake show:*)",
      "Bash(nix fmt:*)",
      "Bash(nix-option:*)",
      "Bash(./bin/nix-option:*)",
      "Bash(darwin-rebuild build:*)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "ask": [
      "Bash(sudo darwin-rebuild switch:*)",
      "Bash(darwin-rebuild switch:*)",
      "Bash(sudo darwin-rebuild:*)",
      "Bash(nix flake update:*)",
      "Bash(nix flake lock:*)",
      "Bash(brew:*)"
    ],
    "deny": [
      "Bash(sudo nix flake update:*)",
      "Bash(sudo nix flake lock:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-nix.sh"
          }
        ]
      }
    ]
  }
}
