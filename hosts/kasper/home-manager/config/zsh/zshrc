# ── Homebrew (migrated from ~/.zprofile) ──────────────────────
# Sets PATH, HOMEBREW_PREFIX/CELLAR/REPOSITORY, MANPATH, INFOPATH.
eval "$(/opt/homebrew/bin/brew shellenv)"

# ── History ────────────────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY          # share history across sessions
setopt HIST_IGNORE_ALL_DUPS   # no duplicate entries
setopt HIST_IGNORE_SPACE      # don't record commands starting with space
setopt HIST_REDUCE_BLANKS     # remove extra blanks
setopt APPEND_HISTORY         # append, don't overwrite

# ── Key Bindings (portable — works in any terminal) ───────────
# Requires terminal to send Option as Alt/Escape (not Unicode).
# In WezTerm: send_composed_key_when_left_alt_is_pressed = false
# In iTerm2: Profiles → Keys → Left Option → Esc+
# In Terminal.app: Profiles → Keyboard → Use Option as Meta Key
bindkey -e                            # emacs mode (the foundation)

# Option+Left / Option+Right → jump word
# Arrow key variants (what Option+Arrow actually sends)
bindkey '\e[1;3D' backward-word       # Alt+LeftArrow
bindkey '\e[1;3C' forward-word        # Alt+RightArrow
# Letter variants (Alt+b / Alt+f — some terminals send these instead)
bindkey '\eb' backward-word
bindkey '\ef' forward-word

# Option+Delete → delete word backward
bindkey '\e\x7f' backward-kill-word   # Alt+Backspace

# Option+Fn+Delete → delete word forward
bindkey '\ed' kill-word               # Alt+d

# Ctrl+U → delete to start of line
bindkey '^U' backward-kill-line

# Ctrl+A / Ctrl+E → start/end of line
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line

# Ctrl+K → delete to end of line
bindkey '^K' kill-line

# ── General Options ───────────────────────────────────────────
setopt AUTO_CD                # type a dir name to cd into it
setopt CORRECT                # offer to correct typos
setopt INTERACTIVE_COMMENTS   # allow # comments in interactive shell
setopt NO_BEEP                # silence

# ── Completion ────────────────────────────────────────────────
autoload -Uz compinit
# Only regenerate .zcompdump once a day (speeds up shell startup)
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# Case-insensitive + partial-word completion
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' menu select
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' use-cache on
zstyle ':completion:*:*:*:*:processes' command "ps -u $USER -o pid,user,comm -w -w"

# ── fzf ───────────────────────────────────────────────────────
eval "$(fzf --zsh)"

# ── fzf-tab (must come AFTER compinit and fzf) ───────────────
source ~/.zsh/fzf-tab/fzf-tab.plugin.zsh
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always $realpath'
zstyle ':fzf-tab:complete:*' fzf-preview 'echo ${(P)word} 2>/dev/null || echo $word'
zstyle ':fzf-tab:*' switch-group '<' '>'

# ── Syntax Highlighting & Autosuggestions ─────────────────────
# Install: brew install zsh-syntax-highlighting zsh-autosuggestions
[[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

[[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
bindkey '^ ' autosuggest-accept      # Ctrl+Space to accept suggestion

# ── Tools ─────────────────────────────────────────────────────
eval "$(zoxide init zsh)"
eval "$(starship init zsh)"
eval "$(fnm env --use-on-cd --shell zsh)"

# ── Aliases ───────────────────────────────────────────────────
alias ls="eza --icons"
alias ll="eza -la --icons"
alias lt="eza --tree --icons --level=2"
alias cat="bat"
alias ..="cd .."
alias ...="cd ../.."
alias mkdir="mkdir -p"

# ── Editor ─-──────────────────────────────────────────────────
export EDITOR="micro"

# ── pnpm ──────────────────────────────────────────────────────
export PNPM_HOME="/Users/kasper/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# ── theme ──────────────────────────────────────────────────────
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#cba6f7,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
--color=selected-bg:#45475a \
--border='rounded'"

# Append a line after prompt instead of prepending
precmd() {
  if [[ -z "$_NEW_LINE_BEFORE_PROMPT" ]]; then
    _NEW_LINE_BEFORE_PROMPT=1
  else
    print ""
  fi
}

# Micro editor truecolor support
export MICRO_TRUECOLOR=1
alias cc='claude'
alias ccy='claude --dangerously-skip-permissions'
export PATH="$HOME/.local/bin:$PATH"

# yazi: `y` opens yazi and cd's the shell to wherever you exit
function y() {
      local tmp cwd
      tmp="$(mktemp -t yazi-cwd.XXXXXX)"
      command yazi "$@" --cwd-file="$tmp"
      if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
              builtin cd -- "$cwd"
      fi
      command rm -f -- "$tmp"
}

# ── yabai scripting-addition auto-heal on `brew upgrade` ───────────────
# yabairc runs `sudo yabai --load-sa` on every start / dock restart, and that's
# passwordless ONLY because /etc/sudoers.d/yabai whitelists that exact command
# keyed to the yabai binary's sha256 (imperative root state — NOT nix-managed).
# A `brew upgrade` that bumps yabai changes the binary hash → the sudoers line
# goes stale → `--load-sa` silently fails → tiling breaks until you re-run
# `sudo yabai --install-sa` and refresh the hash by hand. This wraps `brew` so
# any upgrade that actually changes the yabai binary heals it automatically:
# reinstall the SA, rewrite the sudoers hash (validated with `visudo -c` before
# it can replace the live file, so a bad write can't lock you out of sudo),
# reload the SA. Every other brew command — and an upgrade that leaves yabai
# untouched — passes straight through with no sudo prompt. (skhd needs no SA.)
brew() {
  if [[ "$1" != "upgrade" ]]; then
    command brew "$@"
    return
  fi
  local ybin before after rc tmp
  ybin="$(command -v yabai)"
  [[ -x "$ybin" ]] && before="$(shasum -a 256 "$ybin" | cut -d' ' -f1)"
  command brew "$@"
  rc=$?
  [[ -x "$ybin" ]] && after="$(shasum -a 256 "$ybin" | cut -d' ' -f1)"
  if [[ -n "$after" && "$before" != "$after" ]]; then
    print -P "%F{yellow}⟳ yabai binary changed — healing scripting addition…%f"
    sudo yabai --install-sa
    tmp="$(mktemp)"
    print -r -- "$(whoami) ALL=(root) NOPASSWD: sha256:$after $ybin --load-sa" > "$tmp"
    if sudo visudo -cf "$tmp" >/dev/null; then
      sudo install -m 0440 -o root -g wheel "$tmp" /etc/sudoers.d/yabai
      sudo yabai --load-sa
      print -P "%F{green}✓ yabai SA reinstalled, sudoers hash refreshed, SA reloaded — tiling intact.%f"
    else
      print -P "%F{red}✗ generated sudoers line failed validation — left /etc/sudoers.d/yabai untouched. Refresh by hand.%f"
    fi
    command rm -f -- "$tmp"
  fi
  return $rc
}
