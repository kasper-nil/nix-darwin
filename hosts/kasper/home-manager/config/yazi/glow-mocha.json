{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "bold": true
  },
  "h1": {
    "prefix": "▓▓▓ ",
    "suffix": " ",
    "color": "1",
    "bold": true
  },
  "h2": {
    "prefix": "▓▓▓▓ ",
    "color": "5"
  },
  "h3": {
    "prefix": "▓▓▓▓▓ ",
    "color": "3"
  },
  "h4": {
    "prefix": "▓▓▓▓▓▓ ",
    "color": "2"
  },
  "h5": {
    "prefix": "▓▓▓▓▓▓▓ ",
    "color": "6"
  },
  "h6": {
    "prefix": "▓▓▓▓▓▓▓▓ ",
    "color": "4"
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "8",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "4",
    "underline": true
  },
  "link_text": {
    "color": "12",
    "bold": true
  },
  "image": {
    "color": "4",
    "underline": true
  },
  "image_text": {
    "color": "12",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "1",
    "background_color": "0"
  },
  "code_block": {
    "margin": 2,
    "chroma": {
      "text": {},
      "error": {
        "background_color": "1"
      },
      "comment": {
        "color": "8"
      },
      "comment_preproc": {
        "color": "4"
      },
      "keyword": {
        "color": "5"
      },
      "keyword_reserved": {
        "color": "5"
      },
      "keyword_namespace": {
        "color": "3"
      },
      "keyword_type": {
        "color": "3"
      },
      "operator": {
        "color": "6"
      },
      "punctuation": {
        "color": "7"
      },
      "name": {
        "color": "12"
      },
      "name_builtin": {
        "color": "9"
      },
      "name_tag": {
        "color": "5"
      },
      "name_attribute": {
        "color": "3"
      },
      "name_class": {
        "color": "3"
      },
      "name_constant": {
        "color": "3"
      },
      "name_decorator": {
        "color": "5"
      },
      "name_exception": {},
      "name_function": {
        "color": "4"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "9"
      },
      "literal_date": {},
      "literal_string": {
        "color": "2"
      },
      "literal_string_escape": {
        "color": "5"
      },
      "generic_deleted": {
        "color": "1"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "2"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "6"
      }
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
