# ============================================================================
# skhd – keybindings for yabai
# ============================================================================
# Place this file at: ~/.skhdrc  (this skhd build does NOT read ~/.config/skhd/skhdrc)
# Start skhd:   skhd --start-service
# Restart skhd:  skhd --restart-service
#
# Key reference:
#   alt = option    cmd = command    ctrl = control
#   shift           fn              hyper = cmd + shift + alt + ctrl
#   meh = ctrl + alt + cmd          shift + meh = hyper
# ============================================================================

# ── App Launchers ───────────────────────────────────────────────────────────

# Quake-mode terminal: toggle kitty's built-in quick-access dropdown.
# kitty manages its own show/hide (a floating panel above other apps) — no
# yabai, no scratchpad, no permissions. Config: ~/.config/kitty/quick-access-terminal.conf
ctrl + alt + cmd - t : /Applications/kitty.app/Contents/MacOS/kitten quick-access-terminal
ctrl + alt + cmd - b : open -na "Firefox"

# ── Window Focus ────────────────────────────────────────────────────────────
# Move focus between tiled windows in the current space

ctrl + alt + cmd - left  : yabai -m window --focus west
ctrl + alt + cmd - down  : yabai -m window --focus south
ctrl + alt + cmd - up    : yabai -m window --focus north
ctrl + alt + cmd - right : yabai -m window --focus east

# ── Window Swap ─────────────────────────────────────────────────────────────
# Swap the focused window with a neighbor

hyper - left  : yabai -m window --swap west
hyper - down  : yabai -m window --swap south
hyper - up    : yabai -m window --swap north
hyper - right : yabai -m window --swap east

# ── Switch Workspace ────────────────────────────────────────────────────────
# Focus space N  (requires scripting addition / SIP disabled)

ctrl + alt + cmd - 1 : yabai -m config mouse_follows_focus on; yabai -m space --focus 1; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 2 : yabai -m config mouse_follows_focus on; yabai -m space --focus 2; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 3 : yabai -m config mouse_follows_focus on; yabai -m space --focus 3; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 4 : yabai -m config mouse_follows_focus on; yabai -m space --focus 4; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 5 : yabai -m config mouse_follows_focus on; yabai -m space --focus 5; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 6 : yabai -m config mouse_follows_focus on; yabai -m space --focus 6; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 7 : yabai -m config mouse_follows_focus on; yabai -m space --focus 7; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 8 : yabai -m config mouse_follows_focus on; yabai -m space --focus 8; yabai -m config mouse_follows_focus off
ctrl + alt + cmd - 9 : yabai -m config mouse_follows_focus on; yabai -m space --focus 9; yabai -m config mouse_follows_focus off

# ── Move Window to Workspace ────────────────────────────────────────────────
# Send focused window to space N, then follow focus there

hyper - 1 : yabai -m window --space 1
hyper - 2 : yabai -m window --space 2
hyper - 3 : yabai -m window --space 3
hyper - 4 : yabai -m window --space 4
hyper - 5 : yabai -m window --space 5
hyper - 6 : yabai -m window --space 6
hyper - 7 : yabai -m window --space 7
hyper - 8 : yabai -m window --space 8
hyper - 9 : yabai -m window --space 9

# ── Window Toggles ──────────────────────────────────────────────────────────

# Fullscreen (zoom-fullscreen keeps the window in the BSP tree, just visually fills the space)
ctrl + alt + cmd - f : yabai -m window --toggle zoom-fullscreen

# Toggle float / tiled (centers the floated window at a reasonable size)
ctrl + alt + cmd - v : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Toggle window split direction (vertical <-> horizontal)
ctrl + alt + cmd - e : yabai -m window --toggle split

# ── Resize ──────────────────────────────────────────────────────────────────
# Grow / shrink window in a direction

ctrl + alt + cmd - h : yabai -m window --resize left:-50:0;  yabai -m window --resize right:-50:0
ctrl + alt + cmd - j : yabai -m window --resize bottom:0:50;  yabai -m window --resize top:0:50
ctrl + alt + cmd - k : yabai -m window --resize top:0:-50;    yabai -m window --resize bottom:0:-50
ctrl + alt + cmd - l : yabai -m window --resize right:50:0;   yabai -m window --resize left:50:0

# ── Quick Actions ───────────────────────────────────────────────────────────

# Close focused window; quit the app if it was the last window
ctrl + alt + cmd - q : $HOME/.config/skhd/close-or-quit.sh

# Restart yabai (handy when tweaking config)
shift + ctrl + alt + cmd - r : yabai --restart-service

# Override system minimize/hide (may not work in all apps)
cmd - m : true
cmd - h : true
